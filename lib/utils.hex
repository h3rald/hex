;;; _
;; a -> a
;; Duplicates and prints (with newline) the top item on the stack.
(dup puts) "dputs" ::

;;; when
;; q1 q2 -> *
;; If %:q1%% pushes 0x1 on the stack, dequotes %:q2%%.
(
  ()
  if
) "when" ::

;;; unless
;; q1 q2 -> *
;; If %:q1%% pushes 0x0 on the stack, dequotes %:q2%%.
(
  ()
  swap
  if
) "unless" ::

;;; isi
;; a -> i
;; Pushes %%0x1%% on the stack if %:a%% is an integer, %%0x0%% otherwise.
(
  type "integer" ==
) "isi" ::

;;; iss
;; a -> i
;; Pushes $0x1$$ on the stack if %:a%% is a string, $0x0$$ otherwise.
(
  type "string" ==
) "iss" ::

;;; isq
;; a -> i
;; Pushes $0x1$$ on the stack if %%a%% is a quotation, $0x0$$ otherwise.
(
  type "quotation" ==
) "isq" ::

;;; parentsym
;; -> s
;; Returns the name of the pare t symbol
(
  stacktrace stacktrace len 2 - get
) "parentsym" ::

;;; defined
;; s -> i
;; Pushes $0x1$$ on the stack if a %:s%% is defined, $0x0$$ otherwise.
(
  (s symbols swap index 0x1 >=)
    (0x1)
    (0x0)
  if 
) "defined" ::

;;; let
;; a s ->
;; Stores %:a%% to local variable %:s%%.
(
  "__" parentsym "__" cat cat swap cat :
) "let" ::

;;; bind
;; a s ->
;; Set %:a%% to local variable %:s%% (must exist).
(
  dup
  "__" parentsym "__" cat cat swap cat 
  dup
  (defined)
    (swap pop :)
    (
      pop 
      "[symbol bind] local '" swap "' not found"
      cat cat throw
    ) 
  if
) "bind" ::

;;; _
;; s -> a
;; Pushes the of local variable %:s%% (must exist) on the stack.
(
  dup
  "__" parentsym "__" cat cat swap cat 
  dup
  (defined)
    (swap pop !)
    (
      pop 
      "[symbol _] local '" swap "' not found"
      cat cat throw
    ) 
  if
) "_" ::

;;; i
;; i -> i
;; Throws an error if %:i%% is not an integer.
(
  dup
  (isi not)
    (
      pop
      "[symbol " parentsym "] Integer required"
      cat cat cat throw
    ) 
    () 
  if
) "i" ::

;;; l
;; a -> a
;; Throws an error if %:a%% is not a string or a quotation.
(
  dup dup
  (isi)
    (
      pop
      "[symbol " parentsym "] String or quotation required"
      cat cat cat throw
    ) 
    () 
  if
) "l" ::

;;; s
;; s -> s
;; Throws an error if %:s%% is not a string.
(
  dup
  (iss not)
    (
      pop
      "[symbol " parentsym "] String required"
      cat cat cat throw
    ) 
    () 
  if
) "s" ::

;;; q
;; q -> q
;; Throws an error if %:q%% is not a quotation.
(
  dup
  (isq not)
    (
      pop
      "[symbol " parentsym "] Quotation required"
      cat cat cat throw
    ) 
    () 
  if
) "q" ::

;;; begins
;; s1 s2 -> s3
;; Pushes $0x1$$ on the stack if %:s1%% begins with %:s2%%, or $0x0$$ otherwise.
(
  s "prefix"   let
  s "s"        let
  0x1 "result" let
  0x0 "c"      let
  ("prefix" _ iss not)
    ("[symbol begins] A string prefix is required" throw)
  when
  ("s" _ iss not)
    ("[symbol begins] A string item is required" throw)
  when
  ("s" _ len "prefix" _ len <)
    (0x0 "result" bind)
    (
      (
        "c" _ "prefix" _ len <
        "result" _ and
      )
        (
          (
            "prefix" _ "c" _ get
            "s" _ "c" _ get ==
          )
            ("c" _ 0x1 + "c" bind)
            (0x0 "result" bind)
          if  
        )
      while
    )
  if
  "result" _
  "__begins__result" #
  "__begins__prefix" #
  "__begins__s"      #
  "__begins__c"      # 
) "begins" ::

;;; ends
;; s1 s2 -> s3
;; Pushes $0x1$$ on the stack if %:s1%% ends with %:s2%%, or $0x0$$ otherwise.
(
  s "suffix"   let
  s "s"        let
  0x1 "result" let
   ("suffix" _ iss not)
    ("[symbol ends] A string suffix is required" throw)
  when
  ("s" _ iss not)
    ("[symbol ends] A string item is required" throw)
  when
  "suffix" _ len 0x1 - "c" bind
  ("s" _ len _"suffix" _ len <)
    (0x0 "result" bind)
    (
      "s" _ len "suffix" _ len - "offset" let
      (
        "c" _ 0x0 >=
        "result" _ and
      )
        (
          (
            "suffix" _ "c" _ get
            "s" _ "offset" _ "c" _ + get ==
          )
            ("c" _ 0x1 - "c" bind)
            (0x0 "result" bind)
          if  
        )
      while
    )
  if
  "result" _
  "__ends__suffix" #
  "__ends__s"      #
  "__ends__c"      # 
  "__ends__offset" #
) "ends" ::

;;; gc
;; ->
;; Frees all local symbols.
(
  
  0x0 "c" let
  "__" parentsym "__" cat cat "prefix" let
  ("c" _ symbols len <)
    (
      symbols "c" _ get dup
      ("prefix" _ begins)
        (#)
        (pop)
      if
      "c" _ 0x1 + "c" bind
    )
  while
  "__gc__prefix" #
  "__gc__item"   #
  "__gc__c"      #
) "gc" ::

;; insert
;; (q1|s1) a i -> (q2|s2)
;; Inserts item %:a%% at position %:i%% within a quotation or string.
(
  i "index" let
  l "item"  let
  l "list"  let
  0x0 "is-str" let
  "list" _ len "len" let
  ("index" _ "len" _ >= "index" _ 0x0 < or)
    ("[symbol insert] Index out of bounds" throw)
  when
  ("list" _ iss)
    ( 
      0x1 "is-str" bind
      ("item" _ iss not)
        ("[symbol insert] A string item is required" throw)
      when
      "list" _ "" split "list" bind
    )
  when
  0x0 "c" let
  () "result" bind
  ("c" _ "len" _ <)
    (
      ("c" _ "index" _ ==)
        ("result" _ "item" _ ' cat "result" bind)
      when
      "result" _ "list" _  "c" _ get ' cat "result" bind
      "c" _ 0x1 + "c" bind
    )
  while
  ("is-str" _)
    ("result" _ "" join "result" bind)
  when
  "result" _
  gc
) "insert" ::


;;; push
;; (q1|s1) a -> (q2|s2)
;; Pushes %:a%% to the end of a quotation or string.
(
  "item" let
  l "list" let
  0x0 "is-str" let
  ("list" _ iss)
    (
      ("item" _ iss not)
        ("[symbol push] A string item is required" throw)
      when
      0x1 "is-str" bind
      "list" _ "" split "list" bind
    )
  when
  "list" _ "item" _ ' cat
  ("is-str" _)
    ( "" join)
  when
  gc
) "push" ::


;;; reverse
;; (q1|s1) -> (q2|s2)
;; Reverses the order of the elements in a string or quotation.
(
  l "list" let
  ("list" _ iss)
    ("list" _ "" split "list" bind)
  when
  "list" _ len 0x1 - "c" let
  () "result" let
  ("c" _ 0x0 <=)
    (
       "result" _ "list" _ "c" _ get ' cat "result" bind
       "c" _ 0x1 - "c" bind
    )
  while
  "result" _
  ("list" _ iss)
    ("result" _ "" join "result" bind)
  when
  gc
) "reverse" ::

;;; sort
;; (q1|s1) q2 -> (q3|s2)
;; Sorts the items of a quotation or string.
(
  q "check" let
  l "list" let
  ("list" _ iss)
    ("list" _ "" split "list" bind)
  when
  "list" _ len "len" let
  "list" _ "len" _ 0x1 - "pivot" let
  0x0 "c" let
  () "left" let
  () "right" let
  (0x1 "len" _ <=)
    ("list" _)
    (
      ("c" _ len <)
        (
          ("list" _ "c" _ get "pivot" _ "check" _ .)
            ("left" _ "item" _ push "left" bind)
            ("right" _ "item" _ push "right" bind)
          if
          "c" _ 0x1 + "c" bind
        )
      while
      "left" _ sort "pivot" _ ' "right" _ sort 
      cat cat "result" bind
    )
  if
  ("list" _ iss)
    ("result" _ "" join "result" bind)
  when
  "result" _
  gc
) "sort" ::

;;; replace-all
;; s1 s2 s3 -> s4
;; Replaces all occurrences of %:s2%% with %%s3%% in %:s1%%.
(
  "_rep"  :
  "_src"  :
  "_text" :
  (_text iss _src iss _rep iss and and not)
    ("[symbol replace-all] Three strings required." throw)
  when
  (_text _src index 0x0 >=)
    (_text _src _rep replace "_text" :)
  while
  _text
  cleanup
) "replace-all" :

;;; min
;; q -> a
;; Pushes the minimum item in a quotation on the stack.
(
  "_list" qpop
  () "_result" :
  (_list len 0x0 ==)
    ("[symbol min] Not enough items" throw)
  when
  0x0 get "_result" :
  0x1 "_c" :
  _list len "_len" :
  (_c len <)
    (
      (_result _list _c get <)
        (_list _c get "_result" :)
      when
    )
  while
  _result
  cleanup
) "min" ::

;;; max
;; q -> a
;; Pushes the maximum item in a quotation on the stack.
(
  "_list" qpop
  () "_result" :
  (_list len 0x0 ==)
    ("[symbol max] Not enough items" throw)
  when
  0x0 get "_result" :
  0x1 "_c" :
  _list len "_len" :
  (_c len <)
    (
      (_result _list _c get >)
        (_list _c get "_result" :)
      when
    )
  while
  _result
  cleanup
) "max" ::

;;; intpl
;; s1 q -> s2
;; Substitutes %:$0%% to %%$9%% placeholders in %:s1%% with items in %:q%%.
(
  "_s" spop
  "_q" qpop
  _q len "_len" :
  0x0 "_c" :
  (_c len <)
     (
       _s "$" _c str cat _list _c get cat replace-all "_s" :
       _c 0x1 + "_c" :
     )
   while
   cleanup
) "intpl" ::

;;; each
;; q1 q2 -> *
;; Applies %:q2%% to each element of %:q1%%.
(
  q "fn" let
  q "list" let
  "list" _ len "len" len
  0x0 "c" bund
  ("c" _ "len" _ <)
    (
      "list" _ "c" _ get "fn" _ .
      "c" _ 0x1 + "c" bind
    )
  while
  gc
) "each" ::

;;; map
;; q1 q2 -> q3
;; Returns %:q3%% contains the results of %:q2%% applied to each element of %:q1%%, 
(
  q "fn" let
  q "list" let
  "list" _ len "len" let
  () "result" let
  0x0 "c" let
  ("c" _ "len" _ <)
    (
      "result" _
      "list" _ "c" _ get "fn" _ .
      ' cat "result" bind
      "c" _ 0x1 + "c" bind
    )
  while
  "result" _ 
  gc
) "map2" ::

;;; filter
;; q1 q2-> q3
;; Returns %:q3%% containing only the elements of %:q1%% that satisfy %:q2%%.
(
  "_filter_fn" qpop
  "_filter_list" qpop
  () "_filter_result" :
  _filter_list (
    "_filter_each_item" :
    (_filter_each_item _filter_fn)
      (
        _filter_result _filter_each_item push "_filter_result" :
      ) 
    when
  ) each
  _filter_result
  "_filter_" cleanup
) "filter" ::


;;; slice
;; s1 i1 i2 -> s2
;; Extracts the portion of the string between indices %:i1%% and %:i2%%.
(
  "_slice_end" ipop
  "_slice_start" ipop
  "_slice_str" spop
  _slice_str len "_len" :
  (_slice_start _len >= _slice_start 0x0 < or)
    ("[symbol slice] Start index out of bounds" throw)
  when
  (_slice_end _len >= _slice_end 0x0 < or)
    ("[symbol slice] End index out of bounds" throw)
  when
  (_slice_start _slice_end <)
    (0x0 "_slice_result" :)
    (
      _slice_str _slice_start get _slice_result : 
      _slice_start 0x1 + "_slice_start" :
    )
  while
  (_slice_str iss)
    (_slice_result "" join "_slice_result" :)
  when
  cleanup
) "slice" ::

